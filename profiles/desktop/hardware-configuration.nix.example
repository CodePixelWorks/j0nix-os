# ===========================================================================
# profiles/<profile>/hardware-configuration.nix.example
# ===========================================================================
# Replace this file with the output of:
#   sudo nixos-generate-config --show-hardware-config > profiles/<profile>/hardware-configuration.nix
#
# This file is MACHINE-SPECIFIC. Never check a real one into a public repo
# unless you are comfortable exposing your disk UUIDs.
#
# Architecture boundary (AGENTS.md):
#   This file = host-specific hardware data (filesystems, boot, kernel modules)
#   settings.nix = cross-platform toggles (locale, users, apps)
#   NEVER put filesystems, disk UUIDs, or kernel module lists in settings.nix.
# ===========================================================================
{
  config,
  lib,
  pkgs,
  modulesPath,
  ...
}:

{
  imports = [
    (modulesPath + "/installer/scan/not-detected.nix")
  ];

  # Kernel modules available in initrd for boot-time hardware support.
  boot.initrd.availableKernelModules = [
    "nvme"
    "xhci_pci"
    "ahci"
    "usbhid"
    "usb_storage"
    "sd_mod"
  ];
  boot.initrd.kernelModules = [ ];
  boot.extraModulePackages = [ ];

  # Root filesystem — REPLACE WITH YOUR ACTUAL UUID.
  fileSystems."/" = {
    device = "/dev/disk/by-uuid/REPLACE-ME-ROOT";
    fsType = "ext4";
  };

  # EFI System Partition — REPLACE WITH YOUR ACTUAL UUID.
  fileSystems."/boot" = {
    device = "/dev/disk/by-uuid/REPLACE-ME-EFI";
    fsType = "vfat";
    options = [
      "fmask=0077"
      "dmask=0077"
    ];
  };

  # Swap devices (empty = no swap).
  # For hibernate: add a swap partition/file and configure resume device in
  # the profile's boot.nix or kernel.nix module.
  swapDevices = [ ];

  # Target architecture.
  nixpkgs.hostPlatform = lib.mkDefault "x86_64-linux";

  # CPU microcode updates (auto-enabled when redistributable firmware is on).
  # Adjust vendor: amd or intel.
  hardware.cpu.amd.updateMicrocode = lib.mkDefault config.hardware.enableRedistributableFirmware;
  # hardware.cpu.intel.updateMicrocode = lib.mkDefault config.hardware.enableRedistributableFirmware;
}
