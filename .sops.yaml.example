creation_rules:
  - path_regex: secrets/hosts/.*\.ya?ml$
    age:
      - age1replace-with-your-host-or-admin-recipient
  - path_regex: secrets/users/.*\.ya?ml$
    age:
      - age1replace-with-your-user-recipient
  - path_regex: secrets/common\.ya?ml$
    age:
      - age1replace-with-your-shared-recipient
