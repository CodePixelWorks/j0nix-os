#!/usr/bin/env bash
set -euo pipefail

export PATH="@runtimePath@${PATH:+:$PATH}"

data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
root="${FUSION360_ROOT:-$data_home/autodesk-fusion}"
prefix_log="$root/logs/wineprefixes.log"
prefix="$root/wineprefixes/default"

if [ -f "$prefix_log" ]; then
  logged_prefix="$(awk 'NR == 3 { print; exit }' "$prefix_log")"
  [ -z "$logged_prefix" ] || prefix="$logged_prefix"
fi

status=0
initialized=0
check() {
  label="$1"
  shift
  if "$@"; then
    printf 'ok - %s\n' "$label"
  else
    printf 'not ok - %s\n' "$label"
    status=1
  fi
}

check "wine is available" command -v wine
check "winetricks is available" command -v winetricks
check "install root exists: $root" test -d "$root"
check "wine prefix exists: $prefix" test -d "$prefix"

if [ -f "$prefix_log" ]; then
  initialized=1
  check "prefix log exists" test -f "$prefix_log"
  check "Fusion executable exists" sh -c "find '$prefix' -type f \( -name Fusion360.exe -o -name FusionLauncher.exe \) | grep -q ."
  check "Autodesk Identity Manager exists" sh -c "find '$prefix' -type f -name AdskIdentityManager.exe | grep -q ."
else
  printf 'not ok - prefix log exists (run fusion360-install first)\n'
  printf 'not ok - Fusion executable exists (run fusion360-install first)\n'
  printf 'not ok - Autodesk Identity Manager exists (run fusion360-install first)\n'
fi

if command -v xdg-mime >/dev/null 2>&1; then
  handler="$(xdg-mime query default x-scheme-handler/adskidmgr 2>/dev/null || true)"
  if [ "$handler" = "autodesk-fusion-adskidmgr.desktop" ]; then
    printf 'ok - adskidmgr URL handler is registered\n'
  else
    printf 'not ok - adskidmgr URL handler is %s\n' "${handler:-unset}"
    status=1
  fi
fi

if [ "$initialized" -eq 0 ]; then
  printf 'ok - installation has not been initialized yet\n'
  exit 0
fi

exit "$status"
