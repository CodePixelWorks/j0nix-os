#!/usr/bin/env bash
# Pre-commit hook: ensure README.md is up to date before every commit.
#
# Install with: make install-hooks
# Or manually: cp scripts/git-hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# To bypass (emergency only): git commit --no-verify

set -euo pipefail

# Determine scope from current branch or default to private
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "private")
if [[ "$BRANCH" == "public" ]]; then
    SCOPE="public"
else
    SCOPE="private"
fi

# If the README template or script changed, ALWAYS rebuild README
if git diff --cached --name-only | grep -qE '^(templates/README\.md\.tmpl|scripts/regenerate-readme\.py|Makefile)$'; then
    echo "[hook] README generator inputs changed — regenerating README.md (scope: $SCOPE)"
    python3 scripts/regenerate-readme.py --scope "$SCOPE" --output README.md
    git add README.md
fi

# Verify README is up to date
if ! python3 scripts/regenerate-readme.py --scope "$SCOPE" --check >/dev/null 2>&1; then
    echo ""
    echo "ERROR: README.md is out of date for scope '$SCOPE'."
    echo "       Run: make readme SCOPE=$SCOPE"
    echo "       Or:  python3 scripts/regenerate-readme.py --scope $SCOPE"
    echo ""
    exit 1
fi
